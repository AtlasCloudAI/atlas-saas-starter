// Atlas SaaS Starter — data model
// Postgres in production (Supabase / Neon / Vercel Postgres).
// For zero-config local dev you can switch provider to "sqlite"
// and set DATABASE_URL="file:./dev.db" (remove directUrl).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── NextAuth standard models ──
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  credits       Int       @default(0) // current balance snapshot
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  creations Creation[]
  ledger    CreditLedger[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App models ──
model Creation {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  model      String
  prompt     String   @db.Text
  inputImage String?  @db.Text
  status     String   @default("pending") // pending | processing | completed | failed
  taskId     String?
  getUrl     String?  @db.Text
  outputs    Json?
  error      String?  @db.Text
  cost       Int      @default(0) // credits charged
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CreditLedger {
  id        String   @id @default(cuid())
  userId    String
  delta     Int // +grant / -spend
  reason    String // signup | purchase | redeem | generate | refund
  ref       String? // stripe session id / cdkey / creation id
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Prevents the same Atlas redeem code being used twice in this app.
model RedeemedCode {
  code      String   @id
  userId    String
  amount    Int
  createdAt DateTime @default(now())
}
