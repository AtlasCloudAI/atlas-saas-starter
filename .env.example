# ───────────────────────────────────────────────────────────────
# Atlas SaaS Starter — environment variables
# Copy to `.env` and fill in. Only ATLASCLOUD_API_KEY + DATABASE_URL
# + NextAuth + one payment provider are required to go live.
# ───────────────────────────────────────────────────────────────

# ── Atlas Cloud (the AI engine — this is what you consume) ──
# Get a key at https://atlascloud.ai  (free credits to start)
ATLASCLOUD_API_KEY="apikey-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Base is preset; only change for dev/self-hosted gateways.
ATLASCLOUD_BASE="https://api.atlascloud.ai/api/v1"

# ── Database (Postgres — Supabase / Neon / Vercel Postgres) ──
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Direct (non-pooled) connection for `prisma db push` / migrations.
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Auth (NextAuth + Google OAuth) ──
NEXTAUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-me"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Payments: pick ONE ──
# "stripe" = you bring your own Stripe, you keep 100% of the revenue.
# "atlas"  = redeem-code / Atlas credits flow (no Stripe needed).
PAYMENT_PROVIDER="stripe"

# --- if PAYMENT_PROVIDER=stripe ---
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# --- if PAYMENT_PROVIDER=atlas (redeem codes via Atlas/KubeDL admin API) ---
KUBEDL_ADMIN_BASE="https://console.atlascloud.ai/api/v1"
KUBEDL_ADMIN_APIKEY=""
# Optional header required by some Atlas gateways (dev/MSE).
KUBEDL_ATLAS_HEADER=""
# Credits granted per valid redeem code.
ATLAS_REDEEM_CREDITS="100"

# ── Misc ──
# How many free credits a brand-new signed-up user gets.
SIGNUP_BONUS_CREDITS="20"
